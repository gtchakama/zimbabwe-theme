{
  "name": "Zimbabwe - Light Peace",
  "type": "light",
  "colors": {
    "focusBorder": "#C75B12",
    "foreground": "#24292E",
    "activityBar.background": "#F6F8FA",
    "activityBar.foreground": "#1FA25D",
    "activityBarBadge.background": "#D40000",
    "activityBarBadge.foreground": "#FFFFFF",
    "sideBar.background": "#F6F8FA",
    "statusBar.background": "#1FA25D",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#F6F8FA",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#1FA25D",
    "tab.activeBorder": "#C75B12",
    "tab.inactiveBackground": "#F6F8FA",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#24292E",
    "editorLineNumber.foreground": "#959DA5",
    "editorLineNumber.activeForeground": "#24292E",
    "editorCursor.foreground": "#D40000",
    "editor.lineHighlightBackground": "#FFB00012"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#6A737D", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#D73A49", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#1FA25D" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#C75B12" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#24292E" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#E36209", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#B34700" } },
    { "scope": "support.class, support.type", "settings": { "foreground": "#8A6A2B" } }
  ]
}
