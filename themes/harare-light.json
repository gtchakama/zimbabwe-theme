    { "scope": "variable.parameter", "settings": { "foreground": "#A26B37", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#C25B4A" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#567AB0" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#3D9B6E" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#7B5CC6" } }
