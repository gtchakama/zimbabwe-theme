    "tokenColors": [
        {
            "scope": ["comment"],
            "settings": { "foreground": "#51597d", "fontStyle": "italic" }
        },
        {
            "scope": ["constant.language", "constant.numeric"],
            "settings": { "foreground": "#ff9e64" }
        },
        {
            "scope": ["string"],
            "settings": { "foreground": "#9ece6a" }
        },
        {
            "scope": ["keyword", "storage.type"],
            "settings": { "foreground": "#bb9af7" }
        },
        {
            "scope": ["entity.name.function", "variable.function"],
            "settings": { "foreground": "#7aa2f7" }
        },
        {
            "scope": ["variable", "support.variable"],
            "settings": { "foreground": "#c0caf5" }
        },
        {
            "name": "Parameter",
            "scope": ["variable.parameter"],
            "settings": { "foreground": "#e0af68" }
        }
