    "editorCursor.foreground": "#C96F4A",
    "editor.selectionBackground": "#D8B36A24",
    "editor.inactiveSelectionBackground": "#D8B36A14",
    "editor.selectionHighlightBackground": "#6E8F7B1E",
    "editor.wordHighlightBackground": "#D8B36A1A",
    "editor.lineHighlightBackground": "#FFFFFF06",
    "editorBracketMatch.background": "#D8B36A20",
    "editorBracketMatch.border": "#D8B36A",
    "editorIndentGuide.background": "#3A322D",
    "editorIndentGuide.activeBackground": "#665950",
    "statusBar.background": "#171412",
    "statusBar.foreground": "#C7BAA6",
    "statusBar.border": "#27211D",
    "titleBar.activeBackground": "#171412",
    "titleBar.activeForeground": "#C7BAA6",
    "titleBar.border": "#27211D"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#9D9284", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#C96F4A", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#8FB29D" } },
    { "scope": "entity.name.function, support.function", "settings": { "foreground": "#E4C487" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#EEE7DC" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#D7A46A", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#F28A75" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#9EB8DE" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#8FB29D" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#E4C487" } }
  ]
}
