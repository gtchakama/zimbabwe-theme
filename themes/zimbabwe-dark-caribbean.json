    "editorCursor.foreground": "#FFB000",
    "editor.selectionBackground": "#FFB00033",
    "editor.inactiveSelectionBackground": "#FFB00015",
    "editor.selectionHighlightBackground": "#FFB00022",
    "editor.wordHighlightBackground": "#FFB00022",
    "editor.lineHighlightBackground": "#6E768115",
    "editorBracketMatch.background": "#FFB00033",
    "editorBracketMatch.border": "#FFB000",
    "editorIndentGuide.background": "#21262D",
    "editorIndentGuide.activeBackground": "#30363D",
    "statusBar.background": "#010409",
    "statusBar.foreground": "#8B949E",
    "statusBar.border": "#30363D",
    "titleBar.activeBackground": "#010409",
    "titleBar.activeForeground": "#8B949E",
    "titleBar.border": "#30363D"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#8B949E", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#C75B12", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#1FA25D" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#FFB000" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#E6EDF3" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#FFA657", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#FF7B72" } },
    { "scope": "support.type, support.class", "settings": { "foreground": "#E5C07B" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#1FA25D" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#FFB000" } }
  ]
}
