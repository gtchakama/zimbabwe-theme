    "sideBarSectionHeader.border": "#221B31",
    "editorGroupHeader.tabsBackground": "#15111E",
    "editorGroupHeader.tabsBorder": "#221B31",
    "editorGroup.border": "#221B31",
    "tab.activeBackground": "#20192D",
