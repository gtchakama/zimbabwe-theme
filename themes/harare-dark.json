  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#8B809E", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#F18F4D", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#83D2A8" } },
    { "scope": "entity.name.function, support.function", "settings": { "foreground": "#D7C3FF" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#EEE9F8" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#F8C58C", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#FF8B7D" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#8EB5FF" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#83D2A8" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#D7C3FF" } }
  ]
}
