{
  "name": "Zimbabwe - Victoria Falls Light",
  "type": "light",
  "colors": {
    "focusBorder": "#0C8A94",
    "foreground": "#20313B",
    "selection.background": "#41C7CD26",
    "descriptionForeground": "#627883",
    "errorForeground": "#C8563B",
    "icon.foreground": "#627883",
    "activityBar.background": "#E8F5F7",
    "activityBar.foreground": "#0C8A94",
    "activityBar.inactiveForeground": "#6E8792",
    "activityBar.border": "#C5DDE3",
    "activityBarBadge.background": "#F0AA3C",
    "activityBarBadge.foreground": "#11303A",
    "activityBar.activeBorder": "#F0AA3C",
    "sideBar.background": "#F4FBFC",
    "sideBar.foreground": "#20313B",
    "sideBar.border": "#D9ECEF",
    "sideBarTitle.foreground": "#1F3B45",
    "sideBarSectionHeader.background": "#ECF7F9",
    "sideBarSectionHeader.foreground": "#40616E",
    "sideBarSectionHeader.border": "#D9ECEF",
    "editorGroupHeader.tabsBackground": "#EAF6F8",
    "editorGroupHeader.tabsBorder": "#D9ECEF",
    "editorGroup.border": "#D9ECEF",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#0B5360",
    "tab.border": "#D9ECEF",
    "tab.activeBorder": "#FFFFFF",
    "tab.activeBorderTop": "#41C7CD",
    "tab.inactiveBackground": "#EAF6F8",
    "tab.inactiveForeground": "#6E8792",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#223540",
    "editorLineNumber.foreground": "#94AAB4",
    "editorLineNumber.activeForeground": "#1A313A",
    "editorCursor.foreground": "#D98324",
    "editor.selectionBackground": "#41C7CD26",
    "editor.inactiveSelectionBackground": "#41C7CD18",
    "editor.selectionHighlightBackground": "#F0AA3C1F",
    "editor.wordHighlightBackground": "#41C7CD1F",
    "editor.lineHighlightBackground": "#0C8A940A",
    "editorBracketMatch.background": "#41C7CD20",
    "editorBracketMatch.border": "#0C8A94",
    "editorIndentGuide.background": "#D6E7EB",
    "editorIndentGuide.activeBackground": "#9AB9C2",
    "statusBar.background": "#E8F5F7",
    "statusBar.foreground": "#40616E",
    "statusBar.border": "#C5DDE3",
    "titleBar.activeBackground": "#E8F5F7",
    "titleBar.activeForeground": "#40616E",
    "titleBar.border": "#C5DDE3"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#7A919A", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#C26A20", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#0C8A94" } },
    { "scope": "entity.name.function, support.function", "settings": { "foreground": "#B88118" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#223540" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#2F7D88", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#C8563B" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#466FA5" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#148793" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#B88118" } }
  ]
}
