    { "scope": "string", "settings": { "foreground": "#0C8A94" } },
    { "scope": "entity.name.function, support.function", "settings": { "foreground": "#B88118" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#223540" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#2F7D88", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#C8563B" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#466FA5" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#148793" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#B88118" } }
