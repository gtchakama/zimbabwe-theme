  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#7F98A0", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type, storage.modifier", "settings": { "foreground": "#F6A15C", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#7BE7E0" } },
    { "scope": "entity.name.function, support.function", "settings": { "foreground": "#F7C96D" } },
    { "scope": "variable, variable.other.readwrite", "settings": { "foreground": "#E2EEF0" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#B7E5DF", "fontStyle": "italic" } },
    { "scope": "constant.numeric, constant.language", "settings": { "foreground": "#FF8F70" } },
    { "scope": "support.type, support.class, entity.name.type, entity.name.class", "settings": { "foreground": "#9BC7FF" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#7BE7E0" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#F7C96D" } }
  ]
